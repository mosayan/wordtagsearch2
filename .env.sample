# ==========================================
# 設定ファイル
# このファイルをコピーして「.env」にリネームし、実際のトークンなどを入力。
# ==========================================

# X API認証トークン
# Developer Portalで発行したBearer Token
BEARER_TOKEN=your_bearer_token_here

# 画像の保存先フォルダパス（フォルダは自動作成する）
SAVE_DIR=./downloaded_images

# 検索設定と履歴を管理するExcelファイル名
EXCEL_FILE=download_log.xlsx

# 検索リスト（タグと件数）が入力されているシート名
SEARCH_LIST_SHEET=SearchList

# APIで1回に取得するデフォルトの最大件数（10〜100）
# ※Excelのmax_resultsが空欄の場合はこの値使用
MAX_RESULTS=10